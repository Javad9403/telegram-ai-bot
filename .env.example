BOT_TOKEN=your_bot_token_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your_openai_api_key_here
AI_MODEL=gpt-4o
SYSTEM_PROMPT=You are a helpful Telegram assistant. Respond concisely and accurately. You can search the web when needed to provide accurate, up-to-date information.
REDIS_URL=redis://localhost:6379/0
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_PORT=8443
ADMIN_IDS=
RATE_LIMIT=10

# Web search - Tavily (get free key at https://tavily.com)
TAVILY_API_KEY=your_tavily_api_key

# Proxy (optional) - for web search when bot has no direct internet
HTTP_PROXY=
SOCKS5_PROXY=
