BOT_TOKEN=your_bot_token_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_API_KEY=sk-your_openai_api_key_here
AI_MODEL=gpt-4o
SYSTEM_PROMPT=You are a helpful Telegram assistant. Respond concisely and accurately.
REDIS_URL=redis://localhost:6379/0
USE_WEBHOOK=false
WEBHOOK_URL=
WEBHOOK_PORT=8443
ADMIN_IDS=
RATE_LIMIT=10

# Web search APIs
SERPER_API_KEY=your_serper_api_key
GOOGLE_API_KEY=your_google_custom_search_api_key
GOOGLE_CX=your_google_custom_search_cx
BING_API_KEY=your_bing_search_api_key
BRAVE_API_KEY=your_brave_search_api_key

# Proxy (optional) - for web search when bot has no direct internet
# HTTP_PROXY=http://user:pass@proxy:port
# SOCKS5_PROXY=socks5://user:pass@proxy:port
HTTP_PROXY=
SOCKS5_PROXY=
